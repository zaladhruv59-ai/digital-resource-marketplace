# Airtable Configuration Settings
# Get your Personal Access Token (PAT) from Airtable Developer Hub (https://airtable.com/create/tokens)
# Required Scopes: data.records:read
AIRTABLE_PERSONAL_ACCESS_TOKEN=your_personal_access_token_here

# Get your Base ID from the Airtable API URL or Developer Hub API Docs (https://airtable.com/api)
AIRTABLE_BASE_ID=your_base_id_here

# Name of your table in the base (case-sensitive)
AIRTABLE_TABLE_NAME=Products
