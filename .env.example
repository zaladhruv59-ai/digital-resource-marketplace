# Airtable Connection Credentials
# Create a Personal Access Token (PAT) with "data.records:read" and "data.records:write" scopes
AIRTABLE_PERSONAL_ACCESS_TOKEN=your_airtable_personal_access_token_here
AIRTABLE_BASE_ID=your_airtable_base_id_here
# Optional: Defaults to "Products" if omitted
AIRTABLE_TABLE_NAME=Products

# Resend Email Notification Key
# Sign up at resend.com to fetch your API key
RESEND_API_KEY=re_your_resend_api_key_here

# Client-side Analytics IDs (Publicly accessible variables prefixed with NEXT_PUBLIC_)
# Google Analytics measurement tag (starts with G-)
NEXT_PUBLIC_GA_ID=G-your_measurement_id_here
# Microsoft Clarity project ID
NEXT_PUBLIC_CLARITY_ID=your_clarity_project_id_here
